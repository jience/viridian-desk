{
  "name": "viridian-desk",
  "private": true,
  "version": "2.0.1",
  "packageManager": "pnpm@10.30.3",
  "type": "module",
  "scripts": {
    "tauri": "tauri",
    "dev": "pnpm run prepare-resources && vite",
    "build": "pnpm run lint && vite build && pnpm run check:bundle",
    "check:bundle": "node scripts/check-build-budget.js",
    "check:frontend": "pnpm run check:offline-assets && pnpm run test:e2e && pnpm run build",
    "check:offline-assets": "node scripts/check-offline-assets.js",
    "lint": "pnpm run prepare-resources && eslint . && tsc -b",
    "test:e2e": "playwright test",
    "preview": "vite preview",
    "prepare": "husky install",
    "prettier": "prettier --write ./**/*.{js,ts,tsx,css,scss}",
    "update-i18n": "node scripts/generate-i18n-types.js",
    "prepare-resources": "pnpm run update-i18n"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@reduxjs/toolkit": "^2.11.2",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.26",
    "@tauri-apps/api": "^2.9.1",
    "@tauri-apps/plugin-dialog": "~2.4.2",
    "@tauri-apps/plugin-fs": "^2.4.4",
    "@tauri-apps/plugin-http": "^2.5.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.19",
    "i18next": "^25.7.3",
    "i18next-resources-to-backend": "^1.2.1",
    "lucide-react": "^0.562.0",
    "mitt": "^3.0.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-hook-form": "^7.76.1",
    "react-i18next": "^16.5.0",
    "react-redux": "^9.2.0",
    "react-router": "^7.11.0",
    "validator": "^13.15.26"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.60.0",
    "@tauri-apps/cli": "^2.9.6",
    "@types/node": "^22.19.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/validator": "^13.15.10",
    "@vitejs/plugin-react": "^5.1.2",
    "buffer": "^6.0.3",
    "changelog-parser": "^3.0.1",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^6.1.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "js-yaml": "^4.1.1",
    "postcss-pxtorem": "^6.1.0",
    "prettier": "^3.7.4",
    "sass": "^1.97.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.1",
    "vite": "7.3.0"
  }
}
